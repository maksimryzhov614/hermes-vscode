# hermes-bridge configuration
# Copy this to ~/hermes-bridge/.env and fill in.

# Bind address (0.0.0.0 to expose on all interfaces)
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8643

# Public URL the extension will be told to use in the Telegram approve link.
# This MUST be reachable from the user's phone (where they tap the link).
# Set to your Cloudflare Tunnel / domain / Tailscale-funnel URL.
BRIDGE_PUBLIC_URL=https://hermes.example.com

# These are read from ~/.hermes/.env automatically — do NOT duplicate them here:
#   API_SERVER_KEY        — master key the bridge uses to call api_server
#   TELEGRAM_BOT_TOKEN    — bot that delivers the Approve link
#   TELEGRAM_HOME_CHANNEL — chat id (your own user id) that receives pairing requests
